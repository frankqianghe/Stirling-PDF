{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "PlexPDF",
    "mainBinaryName": "plex-pdf",
    "version": "2.5.3",
    "identifier": "plex.pdf.dev",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev -- --mode desktop",
        "beforeBuildCommand": "node scripts/build-provisioner.mjs && npm run build -- --mode desktop"
    },
    "app": {
        "windows": [
            {
                "title": "PlexPDF",
                "width": 1280,
                "height": 800,
                "minWidth": 1080,
                "minHeight": 700,
                "resizable": true,
                "fullscreen": false,
                "maximized": true,
                "additionalBrowserArgs": "--enable-features=CertVerifierBuiltinFeature"
            }
        ]
    },
    "bundle": {
        "active": true,
        "publisher": "PlexPDF",
        "targets": [
            "deb",
            "rpm",
            "dmg",
            "msi"
        ],
        "icon": [
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/16x16.png",
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/192x192.png"
        ],
        "resources": [
            "libs/*.jar",
            "runtime/jre/**/*"
        ],
        "fileAssociations": [
            {
                "ext": [
                    "pdf"
                ],
                "name": "PDF Document",
                "description": "Open PDF files with PlexPDF",
                "role": "Editor",
                "mimeType": "application/pdf"
            }
        ],
        "linux": {
            "deb": {
                "desktopTemplate": "plexpdf.desktop"
            }
        },
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": "http://timestamp.digicert.com",
            "wix": {
                "fragmentPaths": [
                    "windows/wix/provisioning.wxs",
                    "windows/wix/file-associations.wxs"
                ],
                "componentGroupRefs": [
                    "ProvisioningComponentGroup",
                    "FileAssociationsComponentGroup"
                ]
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15",
            "signingIdentity": null,
            "entitlements": null,
            "providerShortName": null,
            "infoPlist": "Info.plist"
        }
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "fs": {
            "requireLiteralLeadingDot": false
        },
        "deep-link": {
            "desktop": {
                "schemes": [
                    "plexpdf"
                ]
            }
        }
    }
}
